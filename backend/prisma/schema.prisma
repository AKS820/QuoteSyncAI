generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  company          String?
  role             String?
  created_at       DateTime         @default(now())
  sessions         Session[]
  events           Event[]
  demo_sessions    DemoSession[]
  roi_calculations RoiCalculation[]
  magic_links      MagicLink[]
}

model Session {
  id          String   @id @default(cuid())
  user_id     String
  started_at  DateTime @default(now())
  last_active DateTime @default(now()) @updatedAt
  utm_source  String?
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Event {
  id         String   @id @default(cuid())
  user_id    String?
  event_type String
  metadata   Json?
  timestamp  DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([event_type])
  @@index([timestamp])
  @@index([user_id])
}

model DemoSession {
  id         String   @id @default(cuid())
  user_id    String?
  scenario   String?
  actions    Json?
  outcome    String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model RoiCalculation {
  id         String   @id @default(cuid())
  user_id    String?
  inputs     Json
  result     Json
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model MagicLink {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
